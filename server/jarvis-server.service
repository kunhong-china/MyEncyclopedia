[Unit]
Description=Project Jarvis Server
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=jarvisuser
WorkingDirectory=/home/jarvisuser/MyEncyclopedia/server
EnvironmentFile=/home/jarvisuser/MyEncyclopedia/server/.env
ExecStart=/usr/local/go/bin/go run .
Restart=always
RestartSec=10

# Security settings
NoNewPrivileges=true
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=jarvis-server

[Install]
WantedBy=multi-user.target
