[Unit]
Description=Project Jarvis AI Client
After=network.target sound.target

[Service]
ExecStart=/usr/bin/python3 /home/jarvisuser/MyEncyclopedia/client/main.py
WorkingDirectory=/home/jarvisuser/MyEncyclopedia/client
StandardOutput=inherit
StandardError=inherit
Restart=always
User=jarvisuser

[Install]
WantedBy=multi-user.target
