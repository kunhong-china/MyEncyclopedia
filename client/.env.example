# Project Jarvis Client Configuration
# Copy this to .env and update with your server IP

# WebSocket Server URL
JARVIS_SERVER_URL=ws://192.168.1.100:8080/ws

# Wake word (must match openwakeword model)
WAKE_WORD=jarvis

# Whisper model size: tiny, base, small, medium, large
STT_MODEL_SIZE=base

# Recording duration in seconds after wake word
RECORDING_DURATION=5

# Reconnection delay in seconds
RECONNECT_DELAY=5
